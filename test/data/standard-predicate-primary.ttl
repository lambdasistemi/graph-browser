@prefix ex: <https://example.org/standard#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix gb: <https://lambdasistemi.github.io/graph-browser/vocab/terms#> .
@prefix gbk: <https://lambdasistemi.github.io/graph-browser/vocab/kinds#> .
@prefix gbg: <https://lambdasistemi.github.io/graph-browser/vocab/groups#> .

ex:Student a owl:Class ;
  rdfs:label "Student" .

ex:Mentor a owl:Class ;
  rdfs:label "Mentor" .

ex:knows a owl:ObjectProperty ;
  rdfs:label "knows" .

ex:advises a owl:ObjectProperty ;
  rdfs:label "advises" .

ex:alice a gb:Node, gbk:component, ex:Student ;
  gb:nodeId "alice" ;
  rdfs:label "Alice" ;
  gb:group gbg:instances ;
  dcterms:description "Standard Alice description" ;
  foaf:page <https://example.org/alice-doc> .

ex:bob a gb:Node, gbk:component, ex:Mentor ;
  gb:nodeId "bob" ;
  rdfs:label "Bob" ;
  gb:group gbg:instances ;
  dcterms:description "Standard Bob description" ;
  rdfs:seeAlso <https://example.org/bob-doc> .

ex:carol a gb:Node, gbk:component, ex:Student ;
  gb:nodeId "carol" ;
  rdfs:label "Carol" ;
  gb:group gbg:instances ;
  gb:description "GB Carol description" ;
  dcterms:description "Standard Carol description" ;
  gb:externalLink ex:carolLink .

ex:carolLink a gb:ExternalLink ;
  rdfs:label "Carol GB" ;
  gb:url "https://example.org/carol-gb" .

ex:alice ex:knows ex:bob .

[] a rdf:Statement ;
  rdf:subject ex:alice ;
  rdf:predicate ex:knows ;
  rdf:object ex:bob ;
  dcterms:description "Alice knows Bob via standard reification." .

ex:carol ex:advises ex:bob .

ex:carol-advises a gb:EdgeAssertion ;
  gb:from ex:carol ;
  gb:to ex:bob ;
  gb:predicate ex:advises ;
  rdfs:label "advises" ;
  gb:description "GB assertion description wins." .

[] a rdf:Statement ;
  rdf:subject ex:carol ;
  rdf:predicate ex:advises ;
  rdf:object ex:bob ;
  dcterms:description "This description should lose to the gb assertion." .
