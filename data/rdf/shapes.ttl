@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix gb: <https://lambdasistemi.github.io/graph-browser/vocab/terms#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

gb:DatasetShape a sh:NodeShape ;
  sh:targetClass gb:Dataset ;
  sh:property [
    sh:path dcterms:title ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path dcterms:description ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path gb:nodeCount ;
    sh:datatype xsd:integer ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path gb:edgeCount ;
    sh:datatype xsd:integer ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path gb:sourceRepository ;
    sh:datatype xsd:anyURI ;
    sh:maxCount 1
  ] .

gb:NodeShape a sh:NodeShape ;
  sh:targetClass gb:Node ;
  sh:property [
    sh:path gb:nodeId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path rdfs:label ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path gb:group ;
    sh:class gb:Group ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path dcterms:description ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path foaf:page ;
    sh:nodeKind sh:IRI
  ] ;
  sh:property [
    sh:path rdfs:seeAlso ;
    sh:nodeKind sh:IRI
  ] .

gb:GroupShape a sh:NodeShape ;
  sh:targetClass gb:Group ;
  sh:property [
    sh:path rdfs:label ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path gb:groupId ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] .

gb:ReifiedStatementShape a sh:NodeShape ;
  sh:targetClass rdf:Statement ;
  sh:property [
    sh:path rdf:subject ;
    sh:class gb:Node ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path rdf:predicate ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path rdf:object ;
    sh:nodeKind sh:IRI ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path gb:edgeIndex ;
    sh:datatype xsd:integer ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path dcterms:description ;
    sh:datatype xsd:string ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path rdfs:label ;
    sh:datatype xsd:string ;
    sh:maxCount 1
  ] .
