	<http://purl.org/dc/terms/description> "Graph-browser's own CI validation step. Uses the local validate-action with schema-dir pointing at the repo's own schema/ directory. Validates the self-documenting architecture graph data, views, and tutorials on every PR." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#schemas> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "CI Validation" ;
