	<http://www.w3.org/2000/01/rdf-schema#label> "tutorial.schema.json" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "schema-tutorial" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#schema> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/schema-graph> <http://xmlns.com/foaf/0.1/page> <https://lambdasistemi.github.io/graph-browser/schema/graph.schema.json> ;
	<http://purl.org/dc/terms/description> "JSON Schema for graph data (draft 2020-12). Defines the nodes array (id, label, kind, group, description, links) and edges array (source, target, label, description). Node IDs must be kebab-case. Descriptions must be non-empty. Links require label and URI-format url. Used by downstream repos to validate their data and by the LLM prompt builder as context." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#schemas> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "graph.schema.json" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "schema-graph" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#schema> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/schema-config> <http://xmlns.com/foaf/0.1/page> <https://lambdasistemi.github.io/graph-browser/schema/config.schema.json> ;
	<http://purl.org/dc/terms/description> "JSON Schema for configuration. Defines title, description, sourceUrl (URI format), and kinds map. Each kind has a label, hex color (#rrggbb), and Cytoscape shape (enum of 10 shapes). The kinds map drives all visual differentiation — node colors, shapes, badges, and filter buttons come from here." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#schemas> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "config.schema.json" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "schema-config" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#schema> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/repo-manager> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/RepoManager.purs> ;
	<http://purl.org/dc/terms/description> "Left sidebar component for the app variant. Provides a text input for adding repos (owner/repo, GitHub URLs, or Pages URLs), displays the saved repo list with active selection highlighting, and delete buttons. Emits RepoAdded, RepoSelected, and RepoDeleted outputs to Main." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#ui> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "RepoManager" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "repo-manager" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#component> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/repo-discovery> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/RepoDiscovery.purs> ;
	<http://purl.org/dc/terms/description> "Resolves user input into data URLs. Parses multiple input formats (owner/repo, GitHub URLs, Pages URLs), looks for a .graph-browser.json manifest on main then master branch, falls back to convention-based paths. Supports auth tokens for private repos. Returns a DataUrls record with config, graph, tutorial index, and base URL." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#data-loading> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "RepoDiscovery" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "repo-discovery" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#module> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/purescript> <http://xmlns.com/foaf/0.1/page> <https://www.purescript.org/> ;
	<http://purl.org/dc/terms/description> "Strongly-typed functional language that compiles to JavaScript. All application logic is PureScript — types catch errors at compile time, Effects track side effects, and algebraic data types model the domain precisely. JavaScript is only used in FFI wrappers for browser APIs that PureScript cannot access directly." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#external> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "PureScript" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "purescript" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#concept> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/prompt-builder> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/PromptBuilder.purs> ;
	<http://purl.org/dc/terms/description> "Pure functions for assembling LLM prompts. Given a Config, Graph, and selected Node or Edge, produces a markdown-formatted prompt with: element JSON, connected elements, JSON schema URLs, source repo URL, file paths, and PR instructions. The user types their intent; the tool provides all the context. No effects — clipboard is handled by FFI.Clipboard." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#features> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "PromptBuilder" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "prompt-builder" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#module> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/persist> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/Persist.purs> ;
	<http://purl.org/dc/terms/description> "localStorage persistence layer. Saves and restores viewer state (selected node ID, depth, tutorial ID, tutorial step) keyed by graph title. Also persists the repo list globally. Uses Argonaut for JSON serialization. State is saved on every graph render, enabling seamless session recovery." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#data-loading> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Persist" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "persist" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#module> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/nix-flake> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/flake.nix> ;
	<http://purl.org/dc/terms/description> "The build orchestrator. Produces two outputs: app (Main module with repo manager) and lib (Lib module, standalone viewer). Build process: esbuild bundles npm deps (cytoscape + fcose) into deps.js, spago bundles PureScript into index.js, then they're concatenated. mkSpagoDerivation handles PureScript in the Nix sandbox, importNpmLock handles npm deps." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#build> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Nix Flake" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "nix-flake" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#build> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/main> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/Main.purs> ;
	<http://purl.org/dc/terms/description> "The root component for the app variant. Manages the dual-pane layout: RepoManager slot on the left, Viewer slot on the right. Handles repo add/select/delete events, deep linking via ?repo= URL parameter, and auto-loading the first saved repo on startup." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#ui> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Main (App Entry)" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "main" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#component> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/lib-output> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser#projects-using-graph-browser> ;
	<http://purl.org/dc/terms/description> "The embeddable viewer built from the Lib module. No repo management — reads data/ relative to the serving URL. Downstream repos consume it via Nix flake input, copy their data alongside the HTML, and deploy. Used by local-llm-graph, cardano-governance-graph, and any project that wants a self-hosted graph browser." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#outputs> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Lib Output" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "lib-output" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#output> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/lib> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/Lib.purs> ;
	<http://purl.org/dc/terms/description> "The entry point for the lib variant. A thin wrapper that mounts Viewer with hardcoded data URLs pointing to data/config.json, data/graph.json, and data/tutorials/index.json. No repo management — consumers provide their own data alongside the HTML. Used by downstream repos via Nix flake input." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#ui> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Lib (Standalone Entry)" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "lib" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#component> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/halogen> <http://xmlns.com/foaf/0.1/page> <https://github.com/purescript-halogen/purescript-halogen> ;
	<http://purl.org/dc/terms/description> "PureScript UI framework used for all components. Functional reactive architecture: components are pure render functions plus action handlers. State updates via H.modify_, async via Aff monad, parent-child communication via slots and outputs. Every UI element in graph-browser is a Halogen component or HTML helper." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#external> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Halogen" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "halogen" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#concept> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/graph-views> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/Graph/Views.purs> ;
	<http://purl.org/dc/terms/description> "View types, decoding, and graph filtering. A View selects a subset of edges by (source, target, label) triples and includes per-view tours. filterByView computes the visible nodes from matched edges and builds a filtered Graph. Enables multiple topic-specific lenses over a shared node/edge catalog." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#graph-core> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Graph.Views" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "graph-views" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#module> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/graph-types> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/Graph/Types.purs> ;
	<http://purl.org/dc/terms/description> "Core type definitions for the entire application. Defines Node (id, label, kind, group, description, links), Edge (source, target, label, description), Graph (nodes Map, edges Array, forward/backward adjacency), Config (title, description, sourceUrl, kinds), and helper types. All other modules depend on these types." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#types> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Graph.Types" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "graph-types" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#type> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/graph-search> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/Graph/Search.purs> ;
	<http://purl.org/dc/terms/description> "Full-text search across all graph content. Matches against node labels, descriptions, kinds, and edge labels using case-insensitive substring matching. Returns SearchResult (NodeResult or EdgeResult) with up to 12 results shown in a dropdown. Live search on every keystroke." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#graph-core> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Graph.Search" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "graph-search" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#module> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/graph-operations> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/Graph/Operations.purs> ;
	<http://purl.org/dc/terms/description> "Core graph algorithms. neighborhood() collects all nodes within N hops using BFS in both directions via the adjacency maps. subgraph() extracts the visible portion — only edges where both endpoints are in the neighborhood. These power the depth slider: depth 1 shows immediate neighbors, depth 99 shows everything." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#graph-core> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Graph.Operations" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "graph-operations" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#module> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/graph-decode> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/Graph/Decode.purs> ;
	<http://purl.org/dc/terms/description> "JSON decoders for graph.json and config.json. Uses Argonaut decode combinators to parse node arrays, edge arrays, kind definitions, and links. Handles optional fields (links array defaults to empty). The bridge between raw JSON responses and typed PureScript records." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#data-loading> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Graph.Decode" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "graph-decode" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#module> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/graph-cytoscape> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/Graph/Cytoscape.purs> ;
	<http://purl.org/dc/terms/description> "Converts the internal Graph representation to Cytoscape.js Foreign elements. Maps nodes to {data: {id, label, kind}} and edges to {data: {source, target, label}} arrays. The output format is what FFI.Cytoscape expects for rendering. Also identifies the most-connected node for initial selection." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#graph-core> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Graph.Cytoscape" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "graph-cytoscape" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#module> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/graph-build> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/Graph/Build.purs> ;
	<http://purl.org/dc/terms/description> "Constructs the indexed Graph from raw decoded data. Takes arrays of nodes and edges, builds a Map of nodes by ID and forward/backward adjacency maps (Map NodeId (Set NodeId)) for efficient neighborhood traversal. The adjacency maps enable O(1) lookup of all connections from any node." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#graph-core> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Graph.Build" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "graph-build" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#module> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/ffi-url> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/FFI/Url.purs> ;
	<http://purl.org/dc/terms/description> "URL query parameter management. Gets and sets ?repo= and ?view= parameters using URLSearchParams and history.replaceState (no page reload). Enables deep linking: share a URL that auto-loads a specific repo's graph, optionally filtered to a specific view." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#ffi> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "FFI.Url" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "ffi-url" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#ffi> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/ffi-resize> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/FFI/Resize.purs> ;
	<http://purl.org/dc/terms/description> "Makes the repo manager panel resizable by dragging its right edge. Clamps width between 200px and 600px. Uses pointer events (pointerdown/pointermove/pointerup) for cross-device compatibility." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#ffi> ;
