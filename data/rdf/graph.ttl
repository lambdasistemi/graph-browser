	<http://purl.org/dc/terms/description> "JSON Schema for view files (draft 2020-12). Defines name, description, edges array of [source, target, label] triples, and optional tours array. Tours use the same structure as tutorial.schema.json. Used by the validate-action to check view files and by the viewer to load per-view subgraphs." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#schemas> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "view.schema.json" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "schema-view" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#schema> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/schema-tutorial> <http://xmlns.com/foaf/0.1/page> <https://lambdasistemi.github.io/graph-browser/schema/tutorial.schema.json> ;
	<http://purl.org/dc/terms/description> "JSON Schema for guided tours. Defines id, title, description, and a stops array. Each stop references a node ID, depth (integer >= 1), title, and narrative text. Narratives support inline links: [text](node:id) for graph navigation, [text](https://url) for external." ;
