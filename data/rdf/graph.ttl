<https://github.com/lambdasistemi/graph-browser/rdf/node/validate-action> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/tree/main/validate-action> ;
	<http://purl.org/dc/terms/description> "A reusable GitHub Actions composite action that validates any data/ directory. Fetches schemas from graph-browser, runs ajv validation on config, graph, tutorials, and view files. Checks referential integrity: edge endpoints exist, kind references valid, tutorial stops reference real nodes, view edge triples match the catalog, and view tour stops are reachable from view edges." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#schemas> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Validate Action" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "validate-action" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#schema> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/tutorial> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/Tutorial.purs> ;
	<http://purl.org/dc/terms/description> "Decoder and types for tutorial JSON files. A Tutorial has stops, each referencing a node ID with a depth and narrative text. Narratives support inline links: [text](node:id) navigates to a graph node, [text](https://url) opens external. Tutorials are loaded on-demand when the user starts a guided tour." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#data-loading> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Tutorial" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "tutorial" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#module> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/spago> <http://xmlns.com/foaf/0.1/page> <https://github.com/purescript/spago> ;
	<http://purl.org/dc/terms/description> "PureScript package manager and build tool. Resolves dependencies from the PureScript registry, compiles all modules, and bundles the output into a single JavaScript file. graph-browser depends on ~20 packages including halogen, argonaut, fetch, web-html, and ordered-collections." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#build> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Spago" ;
