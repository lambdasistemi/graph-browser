	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#ffi> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/ffi-cytoscape> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/FFI/Cytoscape.purs> ;
	<http://purl.org/dc/terms/description> "JavaScript FFI wrapper for Cytoscape.js. Initializes the graph instance with kind-based styling (colors, shapes from config), registers the fCoSE layout plugin, handles element updates with adaptive layout parameters (edge length, repulsion, node separation scale with graph size). Provides event callbacks for node tap, node hover, and edge hover." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#ffi> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "FFI.Cytoscape" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "ffi-cytoscape" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#ffi> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/ffi-crypto> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/FFI/Crypto.purs> ;
	<http://purl.org/dc/terms/description> "AES-256-GCM encryption via the Web Crypto API. Generates a random key on first use, stores it in localStorage. Encrypts GitHub tokens before storage and decrypts on load. IV is prepended to ciphertext, both base64-encoded. Used by the repo manager for private repo access tokens." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#ffi> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "FFI.Crypto" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "ffi-crypto" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#ffi> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/ffi-clipboard> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/blob/main/src/FFI/Clipboard.purs> ;
	<http://purl.org/dc/terms/description> "Thin wrapper around navigator.clipboard.writeText. Follows the Effect → Promise → Aff pattern used across all FFI modules. Requires a secure context (HTTPS or localhost). Used by the prompt builder's Copy button." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#ffi> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "FFI.Clipboard" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "ffi-clipboard" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#ffi> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/esbuild> <http://xmlns.com/foaf/0.1/page> <https://esbuild.github.io/> ;
	<http://purl.org/dc/terms/description> "JavaScript bundler used for npm dependencies only. Bundles bootstrap.js (which imports cytoscape and cytoscape-fcose) into a single minified IIFE file (~555KB). Runs before spago bundle; the two outputs are concatenated into the final index.js. Chosen for speed — sub-100ms bundling." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#build> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "esbuild" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "esbuild" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#build> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/depth-filtering> <http://purl.org/dc/terms/description> "The key UX innovation. Instead of showing the entire graph (overwhelming), the viewer shows a neighborhood of configurable depth around the selected node. Depth 1 shows immediate neighbors (~5-10 nodes), depth 2 shows two hops (~15-30), depth 99 shows everything. The BFS algorithm uses forward and backward adjacency maps for O(hop-count) traversal." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#philosophy> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Depth-Based Filtering" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "depth-filtering" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#concept> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/data-driven> <http://purl.org/dc/terms/description> "Core principle: the PureScript/JS code contains zero domain-specific knowledge. Every visual element — node kinds, colors, shapes, titles, descriptions — comes from JSON data files. A new knowledge graph on any topic works by providing config.json + graph.json without touching code. This enables the universal viewer and the reusable CI workflow." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#philosophy> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Data-Driven Design" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "data-driven" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#concept> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/cytoscape-js> <http://www.w3.org/2000/01/rdf-schema#seeAlso> <https://github.com/iVis-at-Bilkent/cytoscape.js-fcose> ;
	<http://xmlns.com/foaf/0.1/page> <https://js.cytoscape.org/> ;
	<http://purl.org/dc/terms/description> "Graph visualization library that powers all rendering. Handles node/edge drawing, layout, pan/zoom, selection, and events. Graph-browser uses the fCoSE (compound spring embedder) layout algorithm with adaptive parameters that scale with graph size. Styles are programmatically set from config.json kind definitions." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#external> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Cytoscape.js" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "cytoscape-js" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#concept> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/build-action> <http://xmlns.com/foaf/0.1/page> <https://github.com/lambdasistemi/graph-browser/tree/main/build-action> ;
	<http://purl.org/dc/terms/description> "A reusable GitHub Actions composite action that assembles a deployable graph-browser site from a data/ directory with zero build tools. Downloads the pre-built lib variant from GitHub Pages, copies data alongside it, and generates a view index if views are present. Data repos need only JSON files and this action." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#schemas> ;
	<http://www.w3.org/2000/01/rdf-schema#label> "Build Action" ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#nodeId> "build-action" ;
	<http://purl.org/dc/terms/isPartOf> <https://github.com/lambdasistemi/graph-browser/rdf> ;
	a <https://lambdasistemi.github.io/graph-browser/vocab/kinds#schema> , <https://lambdasistemi.github.io/graph-browser/vocab/terms#Node> .
<https://github.com/lambdasistemi/graph-browser/rdf/node/app-output> <http://xmlns.com/foaf/0.1/page> <https://lambdasistemi.github.io/graph-browser/> ;
	<http://purl.org/dc/terms/description> "The full hosted application built from the Main module. Includes repo manager panel, URL deep linking (?repo=owner/repo), multi-repo state persistence, and token encryption. Deployed to lambdasistemi.github.io/graph-browser/. Users browse any public or private repo's graph data without cloning." ;
	<https://lambdasistemi.github.io/graph-browser/vocab/terms#group> <https://lambdasistemi.github.io/graph-browser/vocab/groups#outputs> ;
