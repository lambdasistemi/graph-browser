@prefix gb: <https://lambdasistemi.github.io/graph-browser/vocab/terms#> .
@prefix gbkind: <https://lambdasistemi.github.io/graph-browser/vocab/kinds#> .
@prefix gbgroup: <https://lambdasistemi.github.io/graph-browser/vocab/groups#> .
@prefix gbedge: <https://lambdasistemi.github.io/graph-browser/vocab/edges#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<https://lambdasistemi.github.io/graph-browser/vocab/application-ontology> a owl:Ontology ;
  rdfs:label "Graph Browser application vocabulary" ;
  dcterms:description "Repository-specific vocabulary generated from graph-browser config and graph data." ;
  owl:imports <https://lambdasistemi.github.io/graph-browser/vocab/ontology> ;
  owl:versionInfo "0.1.0" .

gbkind:build a owl:Class ;
  rdfs:label "Build Tool" ;
  gb:kindId "build" ;
  gb:color "#3fb950" ;
  gb:shape "barrel" ;
  rdfs:subClassOf gb:Node .

gbkind:component a owl:Class ;
  rdfs:label "UI Component" ;
  gb:kindId "component" ;
  gb:color "#f778ba" ;
  gb:shape "round-octagon" ;
  rdfs:subClassOf gb:Node .

gbkind:concept a owl:Class ;
  rdfs:label "Concept" ;
  gb:kindId "concept" ;
  gb:color "#56d364" ;
  gb:shape "star" ;
  rdfs:subClassOf gb:Node .

gbkind:ffi a owl:Class ;
  rdfs:label "FFI Binding" ;
  gb:kindId "ffi" ;
  gb:color "#d2a8ff" ;
  gb:shape "diamond" ;
  rdfs:subClassOf gb:Node .

gbkind:module a owl:Class ;
  rdfs:label "Module" ;
  gb:kindId "module" ;
  gb:color "#58a6ff" ;
  gb:shape "round-rectangle" ;
  rdfs:subClassOf gb:Node .

gbkind:output a owl:Class ;
  rdfs:label "Build Output" ;
  gb:kindId "output" ;
  gb:color "#f0883e" ;
  gb:shape "rectangle" ;
  rdfs:subClassOf gb:Node .

gbkind:schema a owl:Class ;
  rdfs:label "JSON Schema" ;
  gb:kindId "schema" ;
  gb:color "#e3b341" ;
  gb:shape "round-pentagon" ;
  rdfs:subClassOf gb:Node .

gbkind:type a owl:Class ;
  rdfs:label "Data Type" ;
  gb:kindId "type" ;
  gb:color "#79c0ff" ;
  gb:shape "ellipse" ;
  rdfs:subClassOf gb:Node .


gbgroup:build a gb:Group ;
  rdfs:label "build" ;
  gb:groupId "build" .

gbgroup:data-loading a gb:Group ;
  rdfs:label "data-loading" ;
  gb:groupId "data-loading" .

gbgroup:external a gb:Group ;
  rdfs:label "external" ;
  gb:groupId "external" .

gbgroup:features a gb:Group ;
  rdfs:label "features" ;
  gb:groupId "features" .

gbgroup:ffi a gb:Group ;
  rdfs:label "ffi" ;
  gb:groupId "ffi" .

gbgroup:graph-core a gb:Group ;
  rdfs:label "graph-core" ;
  gb:groupId "graph-core" .

gbgroup:outputs a gb:Group ;
  rdfs:label "outputs" ;
  gb:groupId "outputs" .

gbgroup:philosophy a gb:Group ;
  rdfs:label "philosophy" ;
  gb:groupId "philosophy" .

gbgroup:schemas a gb:Group ;
  rdfs:label "schemas" ;
  gb:groupId "schemas" .

gbgroup:types a gb:Group ;
  rdfs:label "types" ;
  gb:groupId "types" .

gbgroup:ui a gb:Group ;
  rdfs:label "ui" ;
  gb:groupId "ui" .


gbedge:assembles%20prompts a owl:ObjectProperty ;
  rdfs:label "assembles prompts" ;
  rdfs:subPropertyOf gb:EdgeRelation ;
  gb:edgeLabel "assembles prompts" ;
  rdfs:domain gb:Node ;
  rdfs:range gb:Node .

